{
    "name": "angel-lsp",
    "displayName": "AngelScript for Perception",
    "description": "AngelScript Language Server pre-configured for Perception.cx — IntelliSense, type checking, bundler, and full API coverage out of the box.",
    "author": "sinnayuh",
    "license": "MIT",
    "version": "0.3.101",
    "repository": {
        "type": "git",
        "url": "https://github.com/sinnayuh/angel-lsp-pcx"
    },
    "publisher": "sinnayuh",
    "categories": [
        "Programming Languages",
        "Debuggers",
        "Snippets"
    ],
    "keywords": [
        "angelscript",
        "perception",
        "perception.cx",
        "lsp",
        "language-server"
    ],
    "bugs": {
        "url": "https://github.com/sinnayuh/angel-lsp-pcx/issues"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "icon": "icons/angelscript.png",
    "activationEvents": [
        "onLanguage:angelscript",
        "onLanguage:angelscript-predefined",
        "workspaceContains:**/*.as",
        "onDebug"
    ],
    "main": "./client/out/extension",
    "contributes": {
        "languages": [
            {
                "id": "angelscript",
                "extensions": [
                    ".as"
                ],
                "configuration": "./language-configuration.json",
                "aliases": [
                    "AngelScript"
                ],
                "icon": {
                    "light": "icons/angelscript.png",
                    "dark": "icons/angelscript.png"
                }
            },
            {
                "id": "angelscript-predefined",
                "extensions": [
                    ".as.predefined"
                ],
                "filenames": [
                    "as.predefined"
                ],
                "configuration": "./language-configuration.json",
                "aliases": [
                    "AngelScript Predefined"
                ],
                "icon": {
                    "light": "icons/angelscript-predefined.png",
                    "dark": "icons/angelscript-predefined.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "angelscript",
                "scopeName": "source.angelscript",
                "path": "./angelscript.tmLanguage.json"
            },
            {
                "language": "angelscript-predefined",
                "scopeName": "source.angelscript",
                "path": "./angelscript.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "angelscript",
                "path": "./snippets.json"
            }
        ],
        "commands": [
            {
                "command": "angelScript.bundle",
                "title": "Bundle Script",
                "category": "AngelScript"
            },
            {
                "command": "angelScript.bundleStripped",
                "title": "Bundle Script (Strip Comments)",
                "category": "AngelScript"
            },
            {
                "command": "angelScript.bundleProject",
                "title": "Bundle Project...",
                "category": "AngelScript"
            },
            {
                "command": "angelScript.bundleAll",
                "title": "Bundle All Projects",
                "category": "AngelScript"
            },
            {
                "command": "angelScript.openSettings",
                "title": "View Settings",
                "category": "AngelScript"
            },
            {
                "command": "angelScript.openDocs",
                "title": "Open Perception Docs",
                "category": "AngelScript"
            },
            {
                "command": "angelScript.initProject",
                "title": "Initialize Project",
                "category": "AngelScript"
            }
        ],
        "keybindings": [
            {
                "command": "angelScript.bundle",
                "key": "ctrl+alt+b",
                "when": "resourceExtname == .as"
            },
            {
                "command": "angelScript.bundleStripped",
                "key": "ctrl+alt+shift+b",
                "when": "resourceExtname == .as"
            }
        ],
        "taskDefinitions": [
            {
                "type": "angelscript-bundle",
                "required": [
                    "src",
                    "out"
                ],
                "properties": {
                    "src": {
                        "type": "string",
                        "description": "Source directory containing .as files (relative to workspace root)"
                    },
                    "out": {
                        "type": "string",
                        "description": "Output bundled file path (relative to workspace root)"
                    },
                    "strip": {
                        "type": "boolean",
                        "description": "Strip comments from the bundled output",
                        "default": false
                    }
                }
            }
        ],
        "semanticTokenTypes": [
            {
                "id": "keywordControl",
                "description": "For keywords that affect control flow.",
                "superType": "keyword"
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "angelscript",
                "scopes": {
                    "keyword": [
                        "keyword.angelscript"
                    ],
                    "keywordControl": [
                        "keyword.control.angelscript"
                    ]
                }
            }
        ],
        "configurationDefaults": {
            "editor.semanticTokenColorCustomizations": {
                "rules": {
                    "builtin": "#00b0e0",
                    "directive": "#ffe020",
                    "metadata": "#bb55ff"
                }
            },
            "[angelscript]": {
                "editor.formatOnType": true
            }
        },
        "configuration": {
            "type": "object",
            "title": "AngelScript configuration",
            "properties": {
                "angelScript.suppressAnalyzerErrors": {
                    "scope": "window",
                    "type": "boolean",
                    "default": true,
                    "description": "Report type-analyzer problems as warnings instead of errors. Recommended (true) — the analyzer is a preview and may produce false positives."
                },
                "angelScript.builtinStringType": {
                    "scope": "window",
                    "type": "string",
                    "default": "string",
                    "description": "The built-in string type used in your application. Can be constructed from string literals."
                },
                "angelScript.builtinArrayType": {
                    "scope": "window",
                    "type": "string",
                    "default": "array",
                    "description": "The built-in array type used in your application. This will handle `Type[]` as `array<Type>`."
                },
                "angelScript.includePath": {
                    "scope": "window",
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "The include paths used to resolve #include. Specify as relative or absolute paths."
                },
                "angelScript.forceIncludePredefined": {
                    "scope": "window",
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Paths to additional `.as.predefined` files injected globally on top of the built-in Perception API. Use this for team-shared types or project-specific classes visible across all files."
                },
                "angelScript.indexExclude": {
                    "scope": "window",
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "output",
                        "node_modules",
                        ".git",
                        "reference"
                    ],
                    "description": "Directory names to skip when indexing the workspace for implicit mutual inclusion. Add any large generated or third-party folders here to speed up startup."
                },
                "angelScript.implicitMutualInclusion": {
                    "scope": "window",
                    "type": "boolean",
                    "default": false,
                    "description": "Project files implicitly include each other (like C# or Java). This works with `as.predefined` as the root."
                },
                "angelScript.hoistEnumParentScope": {
                    "scope": "window",
                    "type": "boolean",
                    "default": false,
                    "description": "Hoist enum members to their parents scope for auto-completion."
                },
                "angelScript.explicitPropertyAccessor": {
                    "scope": "window",
                    "type": "boolean",
                    "default": true,
                    "description": "Controls whether the 'property' keyword is required for virtual property accessors. When set to true, functions must explicitly use the 'property' keyword to be treated as property accessors. When false, compatibility mode for AngelScript prior to v2.33.1 is enabled, and functions with 'get_' or 'set_' prefixes are automatically treated as property accessors."
                },
                "angelScript.allowUnicodeIdentifiers": {
                    "scope": "window",
                    "type": "boolean",
                    "default": false,
                    "description": "Controls the use of international characters in the identifiers"
                },
                "angelScript.supportsTypedEnumerations": {
                    "scope": "window",
                    "type": "boolean",
                    "default": false,
                    "description": "Whether your codebase supports typed enumerations."
                },
                "angelScript.supportsForEach": {
                    "scope": "window",
                    "type": "boolean",
                    "default": false,
                    "description": "Whether your codebase supports the foreach construct."
                },
                "angelScript.supportsDigitSeparators": {
                    "scope": "window",
                    "type": "boolean",
                    "default": false,
                    "description": "Whether your codebase supports C++14-style digit separators."
                },
                "angelScript.characterLiterals": {
                    "scope": "window",
                    "type": "boolean",
                    "default": false,
                    "description": "Whether your codebase uses the `asEP_USE_CHARACTER_LITERALS` option."
                },
                "angelScript.formatter.maxBlankLines": {
                    "scope": "window",
                    "type": "number",
                    "default": 1,
                    "description": "Controls the maximum number of blank lines between contents."
                },
                "angelScript.formatter.indentSpaces": {
                    "scope": "window",
                    "type": "number",
                    "default": 4,
                    "description": "Controls the number of spaces for indentation."
                },
                "angelScript.formatter.useTabIndent": {
                    "scope": "window",
                    "type": "boolean",
                    "default": false,
                    "description": "Controls whether to use tabs for indentation instead of spaces."
                },
                "angelScript.trace.server": {
                    "scope": "window",
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Traces the communication between VS Code and the language server."
                },
                "angelScript.bundler.sourceDirectory": {
                    "scope": "window",
                    "type": "string",
                    "default": "source",
                    "description": "Default source directory for bundling .as files (relative to workspace root). Used when no projects are defined."
                },
                "angelScript.bundler.outputFile": {
                    "scope": "window",
                    "type": "string",
                    "default": "output/bundled.as",
                    "description": "Default output file path for the bundled script (relative to workspace root). Used when no projects are defined."
                },
                "angelScript.bundler.stripComments": {
                    "scope": "window",
                    "type": "boolean",
                    "default": true,
                    "description": "Whether to strip comments by default when bundling."
                },
                "angelScript.projects": {
                    "scope": "window",
                    "type": "array",
                    "default": [],
                    "description": "Define multiple AngelScript projects within a single workspace. Each project has its own source directory, output file, and LSP mode. When defined, projects are isolated — files in one project won't see symbols from another.",
                    "items": {
                        "type": "object",
                        "required": [
                            "name",
                            "sourceDirectory",
                            "outputFile"
                        ],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Display name for this project (shown in bundle picker, status bar, etc.)."
                            },
                            "sourceDirectory": {
                                "type": "string",
                                "description": "Source directory for this project's .as files (relative to workspace root)."
                            },
                            "outputFile": {
                                "type": "string",
                                "description": "Output file path for the bundled script (relative to workspace root, or absolute path)."
                            },
                            "stripComments": {
                                "type": "boolean",
                                "default": true,
                                "description": "Whether to strip comments when bundling this project."
                            },
                            "lspMode": {
                                "type": "string",
                                "enum": [
                                    "full",
                                    "syntaxOnly"
                                ],
                                "default": "full",
                                "description": "LSP mode for this project. 'full' enables all IntelliSense features (completions, hover, go-to-definition, type checking). 'syntaxOnly' provides syntax highlighting and parser errors only — useful for secondary projects you aren't actively developing."
                            }
                        }
                    }
                }
            }
        },
        "breakpoints": [
            {
                "language": "angelscript"
            }
        ],
        "debuggers": [
            {
                "type": "angel-lsp-dap",
                "languages": [
                    "angelscript"
                ],
                "label": "AngelScript Debugger (DAP)",
                "configurationAttributes": {
                    "attach": {
                        "properties": {
                            "address": {
                                "type": "string",
                                "description": "IP address of the DAP server to connect to"
                            },
                            "port": {
                                "type": "number",
                                "description": "Port of the DAP debugger to connect to"
                            }
                        },
                        "required": [
                            "address",
                            "port"
                        ]
                    }
                },
                "initialConfigurations": [
                    {
                        "type": "angel-lsp-dap",
                        "request": "attach",
                        "name": "Attach to AngelScript DAP server",
                        "address": "localhost",
                        "port": 27979
                    }
                ],
                "configurationSnippets": [
                    {
                        "label": "AngelScript Debug: Attach",
                        "description": "Configuration for attaching to a DAP server",
                        "body": {
                            "type": "angel-lsp-dap",
                            "request": "attach",
                            "name": "Attach to AngelScript DAP server",
                            "address": "localhost",
                            "port": 27979
                        }
                    }
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -b && npm run copy-predefined",
        "copy-predefined": "node -e \"const fs=require('fs'),path=require('path');const src=path.join('server','src','predefined');const dst=path.join('server','out','predefined');fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src)){fs.copyFileSync(path.join(src,f),path.join(dst,f));console.log('Copied predefined: '+f);}\"",
        "watch": "tsc -b -w",
        "lint": "eslint ./client/src ./server/src --ext .ts,.tsx",
        "postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
        "test": "sh ./scripts/e2e.sh"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.6",
        "@types/node": "^18.14.6",
        "@typescript-eslint/eslint-plugin": "^7.1.0",
        "@typescript-eslint/parser": "^7.1.0",
        "eslint": "^8.57.0",
        "mocha": "^10.3.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "@vscode/debugadapter": "^1.61.0",
        "@vscode/debugprotocol": "^1.61.0"
    }
}
