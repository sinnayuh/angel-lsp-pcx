// ─────────────────────────────────────────────────────────────────────────────
// PROC API
// ─────────────────────────────────────────────────────────────────────────────

// Handle to an external Windows process. Obtain via ref_process(). Release with deref().
class proc_t {
    void deref();

    uint64 base_address() const;
    uint64 peb() const;
    uint pid() const;
    bool alive() const;

    // ── Unsigned reads ──────────────────────────────────────────────────────
    uint8  ru8(uint64 addr) const;
    uint16 ru16(uint64 addr) const;
    uint32 ru32(uint64 addr) const;
    uint64 ru64(uint64 addr) const;

    // ── Signed reads ────────────────────────────────────────────────────────
    int8  r8(uint64 addr) const;
    int16 r16(uint64 addr) const;
    int32 r32(uint64 addr) const;
    int64 r64(uint64 addr) const;

    // ── Float reads ─────────────────────────────────────────────────────────
    float  rf32(uint64 addr) const;
    double rf64(uint64 addr) const;

    // ── Unsigned writes ─────────────────────────────────────────────────────
    bool wu8(uint64 addr, uint8 v);
    bool wu16(uint64 addr, uint16 v);
    bool wu32(uint64 addr, uint32 v);
    bool wu64(uint64 addr, uint64 v);

    // ── Signed writes ───────────────────────────────────────────────────────
    bool w8(uint64 addr, int8 v);
    bool w16(uint64 addr, int16 v);
    bool w32(uint64 addr, int32 v);
    bool w64(uint64 addr, int64 v);

    // ── Float writes ────────────────────────────────────────────────────────
    bool wf32(uint64 addr, float v);
    bool wf64(uint64 addr, double v);

    // ── String reads/writes ─────────────────────────────────────────────────
    string rs(uint64 addr, int max_chars) const;
    string rws(uint64 addr, int max_chars) const;
    bool ws(uint64 addr, const string &in text);
    bool wws(uint64 addr, const string &in text);

    // ── Bulk reads/writes ───────────────────────────────────────────────────
    void rvm(uint64 addr, uint size, array<uint8> &out out_buf);
    bool wvm(uint64 addr, const array<uint8> &in in_buf);

    void r128(uint64 addr, array<uint8> &out out16) const;
    void r256(uint64 addr, array<uint8> &out out32) const;
    void r512(uint64 addr, array<uint8> &out out64) const;
    bool w128(uint64 addr, const array<uint8> &in in16);
    bool w256(uint64 addr, const array<uint8> &in in32);
    bool w512(uint64 addr, const array<uint8> &in in64);

    // ── Module & pattern scanning ───────────────────────────────────────────
    bool get_module(const string &in name, uint64 &out module_base, uint64 &out module_size) const;
    uint64 find_code_pattern(uint64 search_start, uint64 search_size, const string &in signature) const;
    void find_all_code_patterns(uint64 search_start, uint64 search_size, const string &in signature, array<uint64> &out result) const;

    // ── Advanced memory ─────────────────────────────────────────────────────
    array<uint64>@ get_all_tebs() const;
    array<uint64>@ read_pointer_array(uint64 base, uint count, int offset_delta) const;
    bool read_struct(uint64 addr, dictionary &out result, const dictionary &in desc) const;
    bool read_struct_array(uint64 base, uint count, uint size, array<dictionary>@ &out result, const dictionary &in desc) const;
    uint64 alloc_vm(uint size);
    bool free_vm(uint64 address);
    uint64 get_proc_address(uint64 module_base, const string &in export_name) const;
    uint64 get_import_rdata_address(uint64 module_base, const string &in import_name) const;
    bool virtual_query(uint64 address, uint64 &out region_start, uint64 &out region_size, uint32 &out protection, bool &out heap_likely) const;
    array<dictionary@>@ get_vad_snapshot(bool heap_likely_only) const;
    bool is_valid_address(uint64 address) const;
    array<uint64>@ scan_u32(uint32 value, bool heap_only = false) const;
    array<uint64>@ scan_u64(uint64 value, bool heap_only = false) const;
    array<uint64>@ scan_float(float value, bool heap_only = false) const;
    array<uint64>@ scan_double(double value, bool heap_only = false) const;
    array<uint64>@ scan_string(const string &in value, bool heap_only = false) const;
    array<uint64>@ scan_wstring(const string &in value, bool heap_only = false) const;
    array<uint64>@ scan_pointer(uint64 target, bool heap_only = false) const;

    // ── Game-specific helpers ────────────────────────────────────────────────
    uint64 cs2_get_interface(uint64 module_base, const string &in name) const;
    array<dictionary@>@ cs2_get_schema_dump() const;
}

proc_t ref_process();
proc_t ref_process(uint pid);
proc_t ref_process(const string &in name);

