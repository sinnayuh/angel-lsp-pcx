// ─────────────────────────────────────────────────────────────────────────────
// GUI API
// ─────────────────────────────────────────────────────────────────────────────

class panel_t {
    checkbox_t     add_checkbox(const string &in name, bool initial, bool draw_title = true, bool find_protect = false, bool draw_just_label = false);
    keybind_t      add_keybind(const string &in name, int key, const string &in mode, bool draw_title = true, bool find_protect = false);
    color_picker_t add_color(const string &in name, const array<float> &in rgba, bool find_protect = false);
    slider_double_t add_slider_double(const string &in name, const string &in postfix, double value, double minv, double maxv, double step, bool draw_title = true, bool find_protect = false);
    slider_int_t   add_slider_int(const string &in name, const string &in postfix, int value, int minv, int maxv, int step, bool draw_title = true, bool find_protect = false);
    input_t        add_input(const string &in name, const string &in initial, bool draw_title = true, bool find_protect = false);
    list_t         add_list(const string &in name, const array<dictionary@> &in members, bool draw_title = true, bool find_protect = false);
    multi_select_t add_multi_select(const string &in name, const array<dictionary@> &in options, bool is_expandable, bool draw_title = true, bool find_protect = false);
    single_select_t add_single_select(const string &in name, const array<string> &in options, int initial_index, bool is_expandable, bool draw_title = true, bool find_protect = false);
    button_t       add_button(const string &in name, ButtonFn@ cb, bool find_protect = false);
    void set_active(bool active);
}

class subtab_t {
    panel_t add_panel(const string &in name, bool is_small);
    bool is_valid() const;
    void set_active(bool active);
}

class checkbox_t      { bool get() const; void set(bool v); void set_active(bool active); }
class keybind_t       { void get(int &out key, string &out mode) const; void set(int key, const string &in mode); void set_active(bool active); bool is_pressed() const; }
class color_picker_t  { void get(array<float> &out rgba) const; void set(const array<float> &in rgba); void set_active(bool active); }
class slider_double_t { double get() const; void set(double v); void set_active(bool active); }
class slider_int_t    { int get() const; void set(int v); void set_active(bool active); }
class input_t         { string get() const; void set(const string &in v); void set_active(bool active); }
class list_t          { int get() const; int get_count() const; void clear(); void append(const string &in info1, const string &in info2); void set_active(bool active); void remove(int index) const; void highlight(int index) const; void remove_highlight(int index) const; void hide(int index) const; void show(int index) const; }
class multi_select_t  { void get(array<bool> &out states) const; void set(int index, bool state); void set_active(bool active); }
class single_select_t { int get() const; void set(int index); void set_active(bool active); }
class button_t        { void set_active(bool active); }

subtab_t create_subtab(int parent_tab, const string &in name);

checkbox_t      find_checkbox(int tab, const string &in subtab, const string &in panel, const string &in name);
slider_double_t find_slider_double(int tab, const string &in subtab, const string &in panel, const string &in name);
slider_int_t    find_slider_int(int tab, const string &in subtab, const string &in panel, const string &in name);
input_t         find_input(int tab, const string &in subtab, const string &in panel, const string &in name);
multi_select_t  find_multi_select(int tab, const string &in subtab, const string &in panel, const string &in name);
single_select_t find_single_select(int tab, const string &in subtab, const string &in panel, const string &in name);
keybind_t       find_keybind(int tab, const string &in subtab, const string &in panel, const string &in name);
button_t        find_button(int tab, const string &in subtab, const string &in panel, const string &in name);
color_picker_t  find_color(int tab, const string &in subtab, const string &in panel, const string &in name);
list_t          find_list(int tab, const string &in subtab, const string &in panel, const string &in name);

