class hash_set {
    bool contains(uint64 v) const;
    bool insert(uint64 v);
    bool erase(uint64 v);
    void clear();
    uint size() const;
    bool empty() const;
    void set(uint64 v);
    bool get(uint64 v, uint64 &out value);
    void iter_begin();
    bool iter_next(uint64 &out value);
}

class hash_map {
    void set(uint64 key, ? &in value);
    bool get(uint64 key, ? &out value);
    bool contains(uint64 key);
    bool erase(uint64 key);
    void clear();
    uint size();
    bool empty();
    void iter_begin();
    bool iter_next_key(uint64 &out key);
    bool iter_next(uint64 &out key, ? &out value);
}

