funcdef bool __array_less_t(const ? &in a, const ? &in b);

class array<T> {
    array();
    array(uint length);
    array(uint length, const T &in value);
    array(const array<T> &in other);
    array<T> &opAssign(const array<T> &in other);
    uint length() const;
    uint get_length() const;
    void set_length(uint length);
    bool isEmpty() const;
    void resize(uint length);
    void reverse();
    void insertAt(uint index, const T &in value);
    void insertAt(uint index, const array<T> &in values);
    void insertLast(const T &in value);
    void removeAt(uint index);
    void removeLast();
    void removeRange(uint start, uint count);
    void sortAsc();
    void sortAsc(uint startAt, uint count);
    void sortDesc();
    void sortDesc(uint startAt, uint count);
    void sort(const __array_less_t &in compareFunc, uint startAt = 0, uint count = uint(-1));
    int find(const T &in value) const;
    int find(uint startAt, const T &in value) const;
    int findByRef(const T &in value) const;
    int findByRef(uint startAt, const T &in value) const;
    void clear();
    T &opIndex(uint index);
    const T &opIndex(uint index) const;
}

// Built-in string type. The [BuiltinString] metadata enables string literal assignment.
[BuiltinString]
class string {
    string();
    string(const string &in other);
    string &opAssign(const string &in other);
    string &opAssign(double value);
    string &opAssign(float value);
    string &opAssign(int64 value);
    string &opAssign(uint64 value);
    string &opAssign(bool value);
    string &opAddAssign(const string &in other);
    string &opAddAssign(double value);
    string &opAddAssign(float value);
    string &opAddAssign(int64 value);
    string &opAddAssign(uint64 value);
    string &opAddAssign(bool value);
    string opAdd(const string &in other) const;
    string opAdd_r(const string &in other) const;
    string opAdd(double value) const;
    string opAdd_r(double value) const;
    string opAdd(float value) const;
    string opAdd_r(float value) const;
    string opAdd(int64 value) const;
    string opAdd_r(int64 value) const;
    string opAdd(uint64 value) const;
    string opAdd_r(uint64 value) const;
    string opAdd(bool value) const;
    string opAdd_r(bool value) const;
    bool opEquals(const string &in other) const;
    int opCmp(const string &in other) const;
    bool isEmpty() const;
    uint length() const;
    uint get_length() const;
    void set_length(uint length);
    uint8 &opIndex(uint index);
    const uint8 &opIndex(uint index) const;
    void resize(uint length);
    string substr(uint start = 0, int count = -1) const;
    int findFirst(const string &in text, uint start = 0) const;
    int findFirstOf(const string &in chars, uint start = 0) const;
    int findFirstNotOf(const string &in chars, uint start = 0) const;
    int findLast(const string &in text, int start = -1) const;
    int findLastOf(const string &in chars, int start = -1) const;
    int findLastNotOf(const string &in chars, int start = -1) const;
    void insert(uint pos, const string &in text);
    void erase(uint pos, int count = -1);
    array<string>@ split(const string &in delim) const;
}

class any {
    any();
    any(const any &in other);
    any(? &in value);
    any(int64 &in value);
    any(double &in value);
    any &opAssign(const any &in other);
    void store(? &in value);
    void store(int64 &in value);
    void store(double &in value);
    bool retrieve(? &out value) const;
    bool retrieve(int64 &out value) const;
    bool retrieve(double &out value) const;
}

class dictionaryValue {
    dictionaryValue();
    dictionaryValue(const dictionaryValue &in other);
    dictionaryValue &opAssign(const dictionaryValue &in other);
    dictionaryValue &opAssign(const ? &in value);
    dictionaryValue &opAssign(int64 value);
    dictionaryValue &opAssign(double value);
    void opCast(? &out value) const;
    void opConv(? &out value) const;
    int64 opConv() const;
    double opConv() const;
}

class dictionary {
    dictionary();
    dictionary(const dictionary &in other);
    dictionary &opAssign(const dictionary &in other);
    void set(const string &in key, const ? &in value);
    void set(const string &in key, int64 value);
    void set(const string &in key, double value);
    bool get(const string &in key, ? &out value) const;
    bool get(const string &in key, int64 &out value) const;
